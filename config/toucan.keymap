#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
//#include <dt-bindings/zmk/pointing.h>

#define BASE 0
#define NAV  1
#define NUM  2
#define PAD  3
#define SYM  4
#define FN   5
#define AUX  6
#define SYS  7

&mt {
    quick-tap-ms = <100>;
    global-quick-tap;
    flavor = "tap-preferred";
    tapping-term-ms = <170>;
};

/ {
    combos {
        compatible = "zmk,combos";

        LSYSLD {
            timeout-ms = <50>;
            key-positions = <5 38>;
            bindings = <&tog 7>;
        };

        BT0 {
            bindings = <&bt BT_SEL 0>;
            key-positions = <39 7>;
        };

        BT1 {
            bindings = <&bt BT_SEL 1>;
            key-positions = <39 8>;
        };

        BT2 {
            bindings = <&bt BT_SEL 2>;
            key-positions = <39 9>;
        };

        BT3 {
            bindings = <&bt BT_SEL 3>;
            key-positions = <39 10>;
        };

        BT4 {
            bindings = <&bt BT_SEL 4>;
            key-positions = <39 11>;
        };

        HANGUL {
            bindings = <&kp RIGHT_ALT>;
            key-positions = <30 31>;
        };

        HANJA {
            bindings = <&kp RCTRL>;
            key-positions = <31 32>;
        };

        TASKMGR {
            bindings = <&kp LC(LS(ESCAPE))>;
            key-positions = <0 12 24>;
        };

        COMBO_F2 {
            bindings = <&kp F2>;
            key-positions = <1 2>;
        };

        ALFTF4 {
            bindings = <&kp LA(F4)>;
            key-positions = <2 3>;
        };

        COMBO_F5 {
            bindings = <&kp F5>;
            key-positions = <3 4>;
        };

        COMBO_MINUS {
            bindings = <&kp MINUS>;
            key-positions = <6 18>;
        };

        COMBO_UNDERSOCRE {
            bindings = <&kp UNDER>;
            key-positions = <7 19>;
        };

        COMBO_EQUAL {
            bindings = <&kp EQUAL>;
            key-positions = <8 20>;
        };

        COMBO_PLUS {
            bindings = <&kp PLUS>;
            key-positions = <9 21>;
        };

        COMBO_LPAR {
            bindings = <&kp LEFT_PARENTHESIS>;
            key-positions = <4 16>;
        };

        COMBO_RPAR {
            bindings = <&kp RIGHT_PARENTHESIS>;
            key-positions = <5 17>;
        };

        COMBO_LBKT {
            bindings = <&kp LEFT_BRACKET>;
            key-positions = <2 14>;
        };

        COMBO_RBKT {
            bindings = <&kp RIGHT_BRACKET>;
            key-positions = <3 15>;
        };

        COMBO_FIND {
            bindings = <&kp LC(F)>;
            key-positions = <14 16 15>;
        };

        COMBO_SAVE {
            bindings = <&kp LC(S)>;
            key-positions = <15 14>;
        };

        COMBO_TABCLOSE {
            bindings = <&kp LC(W)>;
            key-positions = <2 15>;
        };

        COMBO_SCREENSHOT {
            bindings = <&kp LG(LS(S))>;
            key-positions = <13 14 16>;
        };

        COMBO_CAPSLOCK {
            bindings = <&kp CAPSLOCK>;
            key-positions = <32 33>;
        };

        BTCLR {
            bindings = <&bt BT_CLR>;
            key-positions = <40 23>;
        };

        FLUENT {
            bindings = <&kp LC(LA(LS(SPACE)))>;
            key-positions = <16 15 14 37>;
        };

        FLUENT_SHORTCUT {
            bindings = <&kp LC(LA(LS(B)))>;
            key-positions = <16 15 14 36>;
        };

        BT_USB {
            bindings = <&out OUT_TOG>;
            key-positions = <39 6>;
        };

        WINMINIMIZE {
            bindings = <&WINMINIMIZE>;
            key-positions = <29 28>;
        };
    };

    HRR: HRR {
        compatible = "zmk,behavior-hold-tap";
        label = "HRR";
        bindings = <&kp>, <&kp>;

        #binding-cells = <2>;
        flavor = "tap-preferred";
        tapping-term-ms = <185>;
    };

    HRL: HRL {
        compatible = "zmk,behavior-hold-tap";
        label = "HRL";
        bindings = <&kp>, <&kp>;

        #binding-cells = <2>;
        flavor = "tap-preferred";
        tapping-term-ms = <185>;
    };

    QLT: QLT {
        compatible = "zmk,behavior-hold-tap";
        label = "QLT";
        bindings = <&mo>, <&kp>;

        #binding-cells = <2>;
        tapping-term-ms = <220>;
        quick-tap-ms = <200>;
        flavor = "balanced";
        retro-tap;
        require-prior-idle-ms = <125>;
    };

    CTRL_CAPS: CTRL_CAPS {
        compatible = "zmk,behavior-tap-dance";
        label = "CTRL_CAPS";
        #binding-cells = <0>;
        bindings = <&kp LCTRL>, <&kp CAPSLOCK>;

        tapping-term-ms = <250>;
    };

    MLT: MLT {
        compatible = "zmk,behavior-hold-tap";
        label = "MLT";
        bindings = <&mo>, <&kp>;

        #binding-cells = <2>;
        tapping-term-ms = <185>;
        hold-while-undecided;
    };

    behaviors {
    };

    macros {
        WINMINIMIZE: WINMINIMIZE {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LA(SPACE) &kp N>;
            label = "WINMINIMIZE";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        BASE {
            display-name = "BASE";
            bindings = <
&gresc      &kp Q            &kp W            &kp E         &kp R              &kp T      &kp Y        &kp U              &kp I         &kp O            &kp P               &kp BSPC
&CTRL_CAPS  &HRL LEFT_GUI A  &HRL LEFT_ALT S  &HRL LCTRL D  &HRL LEFT_SHIFT F  &kp G      &kp H        &HRR LEFT_SHIFT J  &HRR LCTRL K  &HRR LEFT_ALT L  &HRR LEFT_GUI SEMI  &kp SQT
&sk LSHFT   &kp Z            &kp X            &kp C         &kp V              &kp B      &kp N        &kp M              &kp COMMA     &kp DOT          &kp FSLH            &sk RSHFT
                                              &lt 1 ESCAPE  &lt 2 SPACE        &lt 3 TAB  &lt 5 ENTER  &QLT 4 SPACE       &QLT 6 BSPC
            >;
        };

        NAV {
            display-name = "NAV";
            bindings = <
&none      &none         &none         &none      &none           &none          &kp HOME       &kp PAGE_UP  &kp UP      &kp PAGE_DOWN  &kp NON_US_BACKSLASH  &none
&none      &kp LEFT_WIN  &kp LEFT_ALT  &kp LCTRL  &kp LEFT_SHIFT  &none          &kp END        &kp LEFT     &kp DOWN    &kp RIGHT      &kp APOSTROPHE        &none
&kp LC(Y)  &kp LC(Z)     &kp LC(X)     &kp LC(C)  &kp LC(V)       &kp LA(LC(V))  &kp LC(LA(V))  &kp LC(V)    &kp LC(C)   &kp LC(X)      &kp LC(Z)             &kp LC(Y)
                                       &none      &none           &none          &none          &none        &kp DELETE
            >;
        };

        NUM {
            display-name = "NUM";
            bindings = <
&none  &none  &none     &kp UP      &none      &none  &kp KP_DIVIDE    &kp N7        &kp N8        &kp N9        &kp KP_MINUS  &none
&none  &none  &kp LEFT  &kp DOWN    &kp RIGHT  &none  &kp KP_ASTERISK  &kp NUMBER_4  &kp N5        &kp NUMBER_6  &kp KP_PLUS   &none
&none  &none  &none     &none       &none      &none  &kp COMMA        &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &kp EQUAL     &none
                        &kp DELETE  &none      &none  &kp BACKSPACE    &kp DOT       &kp NUMBER_0
            >;
        };

        PAD {
            display-name = "PAD";
            bindings = <
&gresc     &none         &none         &none      &none           &none      &none      &none           &none      &none         &none         &none
&none      &kp LEFT_GUI  &kp LEFT_ALT  &kp LCTRL  &kp LEFT_SHIFT  &none      &mkp MCLK  &kp LEFT_SHIFT  &kp LCTRL  &kp LEFT_ALT  &kp LEFT_GUI  &none
&kp LSHFT  &none         &none         &none      &none           &none      &none      &none           &none      &none         &none         &none
                                       &mkp LCLK  &mkp RCLK       &mkp MCLK  &mkp LCLK  &mkp RCLK       &none
            >;
        };

        SYM {
            display-name = "SYM";
            bindings = <
&none  &kp TILDE          &kp AMPERSAND    &kp ASTERISK  &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &kp TILDE          &kp AMPERSAND    &kp ASTERISK  &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &none
&none  &kp LEFT_BRACKET   &kp DOLLAR       &kp PERCENT   &kp CARET             &kp MINUS              &kp LEFT_BRACKET   &kp DOLLAR       &kp PERCENT   &kp CARET             &kp MINUS              &none
&none  &kp RIGHT_BRACKET  &kp EXCLAMATION  &kp AT_SIGN   &kp HASH              &kp NON_US_BACKSLASH   &kp RIGHT_BRACKET  &kp EXCLAMATION  &kp AT_SIGN   &kp HASH              &kp NON_US_BACKSLASH   &none
                                           &none         &none                 &none                  &none              &none            &none
            >;
        };

        FN {
            display-name = "FN";
            bindings = <
&none  &none  &kp F7  &kp F8  &kp F9  &kp F10  &none  &kp F7  &kp F8  &kp F9  &kp F10  &none
&none  &none  &kp F4  &kp F5  &kp F6  &kp F11  &none  &kp F4  &kp F5  &kp F6  &kp F11  &none
&none  &none  &kp F1  &kp F2  &kp F3  &kp F12  &none  &kp F1  &kp F2  &kp F3  &kp F12  &none
                      &none   &none   &none    &none  &none   &none
            >;
        };

        AUX {
            display-name = "AUX";
            bindings = <
&none      &none         &none         &none      &none           &none          &kp HOME       &kp PAGE_UP  &kp UP      &kp PAGE_DOWN  &kp NON_US_BACKSLASH  &none
&none      &kp LEFT_WIN  &kp LEFT_ALT  &kp LCTRL  &kp LEFT_SHIFT  &none          &kp END        &kp LEFT     &kp DOWN    &kp RIGHT      &kp APOSTROPHE        &none
&kp LC(Y)  &kp LC(Z)     &kp LC(X)     &kp LC(C)  &kp LC(V)       &kp LA(LC(V))  &kp LC(LA(V))  &kp LC(V)    &kp LC(C)   &kp LC(X)      &kp LC(Z)             &kp LC(Y)
                                       &none      &none           &none          &none          &none        &kp DELETE
            >;
        };

        SYS {
            display-name = "SYS";
            bindings = <
&bt BT_CLR  &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &none      &none       &none        &none  &none         &none
&none       &none         &none         &none         &none         &none         &none      &none       &none        &none  &none         &none
&none       &out OUT_TOG  &to 0         &bootloader   &sys_reset    &soft_off     &soft_off  &sys_reset  &bootloader  &to 0  &out OUT_TOG  &none
                                        &none         &none         &none         &none      &none       &none
            >;
        };
    };
};
